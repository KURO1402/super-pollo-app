class cambiarClaveModel {
  final String claveActual;
  final String nuevaClave;

  cambiarClaveModel({
    required this.claveActual,
    required this.nuevaClave,
  });

  factory cambiarClaveModel.fromJson(Map<String, dynamic> json) {
    return cambiarClaveModel(
      claveActual: json['clave_actual'],
      nuevaClave: json['nueva_clave']
    );
  }
}